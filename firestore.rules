rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access for products, collections, and slideshow
    match /products/{document=**} {
      allow read: if true;
    }
    match /collections/{document=**} {
      allow read: if true;
    }
    match /slideshow/{document=**} {
      allow read: if true;
    }
    
    // Admin operations (collections, slideshow management)
    match /collections/{document=**} {
      allow write: if request.auth != null;
    }
    match /slideshow/{document=**} {
      allow write: if request.auth != null;
    }
    match /products/{document=**} {
      allow write: if request.auth != null;
    }
    
    // User data
    match /users/{document=**} {
      allow read, write: if true;
    }
    
    // Orders
    match /orders/{document=**} {
      allow read, write: if true;
    }
    
    // Default deny for other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}